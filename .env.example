# ============================================
# AxioVital Provider Operating Environment
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in values
# DO NOT commit .env to version control

# ---- General ----
NODE_ENV=development
APP_NAME=axiovital-provider
APP_VERSION=0.1.0

# ---- Frontend ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# ---- Backend (NestJS) ----
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600
CORS_ORIGINS=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=axiovital
DATABASE_USER=axiovital_user
DATABASE_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ---- OpenSearch ----
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_PROTOCOL=http
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change-me-in-production
OPENSEARCH_URL=${OPENSEARCH_PROTOCOL}://${OPENSEARCH_HOST}:${OPENSEARCH_PORT}

# ---- AI Service (FastAPI) ----
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_LOG_LEVEL=info

# ---- Docker ----
COMPOSE_PROJECT_NAME=axiovital

# ---- Electron (Desktop) ----
ELECTRON_DEV_URL=http://localhost:3000
