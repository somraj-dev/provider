# AxioVital AI Service Environment
# Copy to .env and configure

APP_NAME=axiovital-ai
APP_VERSION=0.1.0
DEBUG=false

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

DATABASE_URL=postgresql://axiovital_user:change-me@localhost:5432/axiovital
REDIS_URL=redis://localhost:6379
BACKEND_URL=http://localhost:4000

CORS_ORIGINS=["http://localhost:3000","http://localhost:4000"]
